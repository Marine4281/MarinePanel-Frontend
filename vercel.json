{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://marinepanel-backend.onrender.com/api/$1"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|TelegramBot|LinkedInBot|Slackbot|Discordbot).*"
        }
      ],
      "destination": "https://marinepanel-backend.onrender.com/api/seo/og-preview"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
